# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://user:password@host.neon.tech/nobug?sslmode=require"

# Better Auth
BETTER_AUTH_SECRET="generate-a-random-32-char-secret-here"

# Resend (email)
RESEND_API_KEY=""

# AWS S3 (optional — uploads no-op when not set)
AWS_REGION=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""

# OAuth (optional for V1)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
